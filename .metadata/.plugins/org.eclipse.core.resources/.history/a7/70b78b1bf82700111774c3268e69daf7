package com.orangehrm.seleniumuiframwework.recruitment;

import java.io.IOException;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebElement;
import org.testng.Reporter;
import org.testng.annotations.Test;
import org.testng.asserts.SoftAssert;

import com.orangehrm.seleniumuiframework.object_repository.AddVacancyPage;
import com.orangehrm.seleniumuiframework.object_repository.DashBoardPage;
import com.orangehrm.seleniumuiframework.object_repository.RecruitmentPage;
import com.orangehrm.seleniumuiframework.object_repository.VacanciesPage;
import com.orangehtm.seleniumuiframework.genericutility.ActionsHelper;
import com.orangehtm.seleniumuiframework.genericutility.BaseClass;
import com.orangehtm.seleniumuiframework.genericutility.ExcelUtility;

public class CreateVacancyTest extends BaseClass {

    @Test
    public void addVacancy() throws IOException {

        ExcelUtility eu = new ExcelUtility();
        RecruitmentPage rp = new RecruitmentPage(driver);
        VacanciesPage vp = new VacanciesPage(driver);
        AddVacancyPage addvp = new AddVacancyPage(driver);
        SoftAssert sa = new SoftAssert();

        DashBoardPage dsp = new DashBoardPage(driver);
        ActionsHelper ah = new ActionsHelper(driver);

        // Dashboard
        dsp.clickRecuitment();

        // Recruitment page
        rp.clickVacancieslink();

        // Vacancies
        vp.clickAddbtn();

        // Load Excel
        eu.loadExcelFile("C:\\Users\\91934\\OneDrive\\Desktop\\vacancies1.xlsx","addVacancy");

        // Fill form
        addvp.setVacancyNameTextField(
                eu.getStringDataFromSingleCell(1, 1));

        ah.navigateDownDropdown(addvp.getJobTitle(), 5, 2);

        addvp.setDescriptionTextField(
                eu.getStringDataFromSingleCell(1, 2));

        ah.scrollDownAutoSuggestion(
                addvp.getHiringManagerTextField(), "a", 7, 1);

        addvp.setNoOfPositionsTextField(
                eu.getStringDataFromSingleCell(1, 3));

        addvp.clickSavebtn();

        // Validation
        List<WebElement> validationVacancyName = driver.findElements(
                By.xpath("//div[@class='oxd-table-row oxd-table-row--with-border']")
        );

        for (WebElement vacancyName : validationVacancyName) {

            String name = vacancyName.getText();

            sa.assertEquals(name,
                    eu.getStringDataFromSingleCell(1, 3));

            if (name.equals(eu.getStringDataFromSingleCell(1, 3))) {
                Reporter.log("Test Case Status: Pass", true);
            } else {
                Reporter.log("Test Case Status: Fail", true);
            }
        }

        sa.assertAll();
    }
}
package Demo;

import java.io.IOException;

import java.nio.file.Files;
import java.nio.file.Paths;
import java.time.Duration;

import org.json.JSONObject;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.annotations.Test;

public class LoginUsingJsonOR {
	@Test
	public void login() throws IOException {
		String data = new String(
				Files.readAllBytes(Paths.get("./src/main/resources/DemoObjectRepository/LoginPage.json")));
		JSONObject obj = new JSONObject(data);
		JSONObject loginPge = obj.getJSONObject("login");
		// Extracting the data to check
		String usernameTextField = loginPge.getString("un");
		String passwordTextField = loginPge.getString("pass");
		String loginbtn = loginPge.getString("loginbutton");
		// splitting the string values to use in locator
		String[] userloc = usernameTextField.split(":");
		String[] passwordloc = passwordTextField.split(":");
		String[] loginloc = loginbtn.split(":");

		// test script
		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(30));
		driver.get("https://opensource-demo.orangehrmlive.com/web/index.php");

		// Username
		if (userloc[0].equals("name")) {
			driver.findElement(By.name(userloc[1])).sendKeys("Admin");
		}

		// Password
		if (passwordloc[0].equals("name")) {
			driver.findElement(By.name(passwordloc[1])).sendKeys("admin123");
		}

		// Login Button
		if (loginloc[0].equals("cssSelector")) {
			driver.findElement(By.name(loginloc[1])).click();
		}

	}
}
